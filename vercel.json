{
  "buildCommand": "cd REDBUS-CLONE-MEAN-main/REDBUS-CLONE-MEAN-main/frontend && npm install && npm run build",
  "outputDirectory": "REDBUS-CLONE-MEAN-main/REDBUS-CLONE-MEAN-main/frontend/dist/frontend/browser",
  "framework": null,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/auth/:path*", "destination": "/api/server" },
    { "source": "/customer", "destination": "/api/server" },
    { "source": "/customer/", "destination": "/api/server" },
    { "source": "/customer/:path*", "destination": "/api/server" },
    { "source": "/routes", "destination": "/api/server" },
    { "source": "/routes/:path*", "destination": "/api/server" },
    { "source": "/booking", "destination": "/api/server" },
    { "source": "/booking/", "destination": "/api/server" },
    { "source": "/booking/:path*", "destination": "/api/server" },
    { "source": "/health", "destination": "/api/server" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
